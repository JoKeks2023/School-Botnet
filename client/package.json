{
  "name": "classroom-cluster-client",
  "version": "1.0.0",
  "description": "Classroom Distributed Art/Compute Cluster – Portable Electron Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable",
    "build:linux": "electron-builder --linux AppImage"
  },
  "dependencies": {
    "socket.io-client": "^4.6.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "de.school.cluster.client",
    "productName": "ClusterClient",
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }]
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "worker/**/*",
      "!node_modules/electron-builder/**"
    ]
  }
}
