{
  "name": "school-botnet-admin-macos",
  "version": "0.1.0",
  "description": "Native macOS Admin Dashboard app with sACN receiver",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.schoolbotnet.admin",
    "productName": "School-Botnet Admin",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html"
    ]
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  }
}